# ╔══════════════════════════════════════════════════════╗
# ║  ContentMind AI — Environment Variables              ║
# ║  Copy to .env and fill in your API keys              ║
# ╚══════════════════════════════════════════════════════╝

# ── Brand Identity ──────────────────────────────────────
BRAND_NAME=Ashmeet
AUTHOR_NAME=Ashmeet
AUTHOR_BIO=Building in public at 14. AI · Business · Innovation.
NICHE=AI, Business, Innovation, Psychology
SIGNATURE=Built Different. Built Deliberately.
TIMEZONE=Asia/Kolkata

# ── AI API Keys (get one) ───────────────────────────────
# OpenAI → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OR Anthropic Claude → https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

AI_MODEL=gpt-4o

# ── Instagram Graph API ─────────────────────────────────
# Guide: https://developers.facebook.com/docs/instagram-api
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── YouTube Data API v3 ─────────────────────────────────
# Guide: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# ── Twitter/X API v2 ────────────────────────────────────
# Guide: https://developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── Notion API ──────────────────────────────────────────
# Guide: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=

# ── Research APIs (recommended, free tiers) ─────────────
# Serper: 2500 free searches → https://serper.dev
SERPER_API_KEY=

# NewsAPI: 100 free/day → https://newsapi.org
NEWS_API_KEY=

# ── Agent Behaviour ─────────────────────────────────────
DRY_RUN=false
CONTENT_TONE=confident, direct, ambitious, authentic
